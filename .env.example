# Copy to .env and adjust. Do NOT commit your real .env.

# General
APP_ENV=production

# Storage (inside the container these map onto the /data volume)
DATA_DIR=/data
DATABASE_PATH=/data/trmnl.db
RENDERED_IMAGES_DIR=/data/rendered

# Device identity / auth (the device must send: Authorization: Bearer <DEVICE_TOKEN>)
# Single-device mode: these are used when NO DEVICE_<n>_* vars are set below.
DEVICE_ID=m5paper-color-01
DEVICE_TOKEN=please-change-this-device-token
# Panel family: "m5" (M5 Paper Color, 400x600 PNG) or "e1004" (reTerminal
# E1004, 1200x1600 packed frame).
DEVICE_TYPE=m5

# --- Multi-device (optional) -------------------------------------------------
# To run several independent devices in this one process -- each with its own
# Telegram bot, SQLite DB, render queue, settings and data dir -- define
# DEVICE_<n>_<FIELD> vars, where <FIELD> is any setting name. Each index <n>
# becomes one device. When ANY DEVICE_<n>_* var is present the single DEVICE_*
# block above is ignored; otherwise it is used as-is. Global config below
# (timezone, mode API keys, Home Assistant, PUBLIC_BASE_URL, ...) is always
# shared across all devices. DEVICE_<n>_DEVICE_ID is required per device; if
# DEVICE_<n>_DATA_DIR is set, database_path/rendered_images_dir default to
# <data_dir>/trmnl.db and <data_dir>/rendered. Uncomment to enable:
#
# DEVICE_1_DEVICE_ID=m5paper-color-01
# DEVICE_1_DEVICE_TYPE=m5
# DEVICE_1_DEVICE_TOKEN=please-change-this-m5-token
# DEVICE_1_TELEGRAM_BOT_TOKEN=111111:AAAA-your-m5-bot-token
# DEVICE_1_TELEGRAM_ALLOWED_USER_IDS=12345678
# DEVICE_1_DATA_DIR=/data/m5
#
# DEVICE_2_DEVICE_ID=reterminal-e1004-01
# DEVICE_2_DEVICE_TYPE=e1004
# DEVICE_2_DEVICE_TOKEN=please-change-this-e1004-token
# DEVICE_2_TELEGRAM_BOT_TOKEN=222222:BBBB-your-e1004-bot-token
# DEVICE_2_TELEGRAM_ALLOWED_USER_IDS=12345678
# DEVICE_2_DATA_DIR=/data/e1004
# -----------------------------------------------------------------------------

# Public base URL where the device reaches this backend.
# When deployed via docker-compose the host port is 17555 (container: 8000).
PUBLIC_BASE_URL=http://localhost:17555

# Telegram
TELEGRAM_BOT_TOKEN=
# Comma or space separated numeric Telegram user IDs allowed to use the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Retention: keep only this many most-recent rendered images per device (older
# PNGs + DB rows are pruned after each render). Images still in the active
# carousel or currently shown on the device are always kept.
KEEP_RENDERED_IMAGES=5

# Scheduling
DEFAULT_INTERVAL_MINUTES=60
TIMEZONE=Asia/Jerusalem
NIGHT_MODE_START=23:00
NIGHT_MODE_END=06:30

# Device-health alerts (sent via Telegram). Active whenever the bot token and
# TELEGRAM_ALLOWED_USER_IDS are set. LOW_BATTERY_PERCENT triggers a charge
# reminder; the device is flagged offline once it misses its expected next
# check-in by OFFLINE_GRACE_MINUTES.
LOW_BATTERY_PERCENT=20
OFFLINE_GRACE_MINUTES=15

# HTTP server
HOST=0.0.0.0
PORT=8000

# Weather mode (OpenWeatherMap). Get a free key at https://openweathermap.org/api
# The "weather" mode shows a hint until OPENWEATHER_API_KEY is set.
OPENWEATHER_API_KEY=
WEATHER_CITY=Tel Aviv,IL
WEATHER_UNITS=metric
WEATHER_LANG=en

# Van Gogh mode (no API key required; Wikidata + Wikimedia Commons). Artist is
# configurable by Wikidata QID (default Q5582 = Vincent van Gogh; e.g. Q296 =
# Monet, Q5598 = Caravaggio).
VAN_GOGH_ARTIST_QID=Q5582

# Home Assistant presence gate (optional). When all three are set, the display
# is held (not refreshed) while nobody is home. Leave HOME_ASSISTANT_URL or
# HOME_ASSISTANT_TOKEN blank to disable the check entirely. The token grants
# full control of your home -- keep this file out of git.
# Presence entities are person/device_tracker IDs; "home" if ANY is home.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_PRESENCE_ENTITIES=person.me, person.partner

# "Now Playing" mode (optional). A media_player entity whose current artwork is
# shown full-screen. Reuses HOME_ASSISTANT_URL/TOKEN above; the "now_playing"
# mode shows a hint until this entity is set. Holds the display when idle.
HOME_ASSISTANT_MEDIA_PLAYER_ENTITY=media_player.gostinaia
