# Copy to .env and adjust. Do NOT commit your real .env.

# General
APP_ENV=production

# Storage (inside the container these map onto the /data volume)
DATA_DIR=/data
DATABASE_PATH=/data/trmnl.db
RENDERED_IMAGES_DIR=/data/rendered

# Device identity / auth (the device must send: Authorization: Bearer <DEVICE_TOKEN>)
DEVICE_ID=m5paper-color-01
DEVICE_TOKEN=please-change-this-device-token

# Public base URL where the device reaches this backend.
# When deployed via docker-compose the host port is 17555 (container: 8000).
PUBLIC_BASE_URL=http://localhost:17555

# Telegram
TELEGRAM_BOT_TOKEN=
# Comma or space separated numeric Telegram user IDs allowed to use the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Scheduling
DEFAULT_INTERVAL_MINUTES=60
TIMEZONE=Asia/Jerusalem
NIGHT_MODE_START=23:00
NIGHT_MODE_END=06:30

# HTTP server
HOST=0.0.0.0
PORT=8000

# Image rendering (photos). Spectra-6 has no neutral grays, so photos are
# pre-lightened before quantization. EINK_GAMMA < 1.0 brightens midtones
# (1.0 disables it); EINK_AUTOCONTRAST stretches the tonal range.
EINK_GAMMA=0.75
EINK_AUTOCONTRAST=true

# Weather mode (OpenWeatherMap). Get a free key at https://openweathermap.org/api
# The "weather" mode shows a hint until OPENWEATHER_API_KEY is set.
OPENWEATHER_API_KEY=
WEATHER_CITY=Tel Aviv,IL
WEATHER_UNITS=metric
WEATHER_LANG=en
