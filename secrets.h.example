#pragma once

// ===========================================================================
// Local site configuration & secrets  (template)
// ===========================================================================
// Copy this file to secrets.h and fill in your own values. secrets.h is
// gitignored; this .example is committed to document the expected shape.
// Included by m5color_trmnl.ino after <WiFi.h>, so IPAddress is available.

#include <WiFi.h>

// --- WiFi credentials ---
static const char *WIFI_SSID     = "your-wifi-ssid";
static const char *WIFI_PASSWORD = "your-wifi-password";

// --- Backend (no trailing slash) + device identity ---
// DEVICE_ID / DEVICE_TOKEN must match the backend configuration.
static const char *BACKEND_URL   = "http://192.168.1.230:17555";
static const char *DEVICE_ID     = "m5paper-color-01";
static const char *DEVICE_TOKEN  = "change-me-device-token";

// --- Static IP ---
// Set STATIC_IP_ENABLED to 0 to fall back to DHCP. A static lease also speeds
// up association (no DHCP round-trip), which helps battery life.
#define STATIC_IP_ENABLED 1
static const IPAddress STATIC_IP      (192, 168, 1, 205);
static const IPAddress STATIC_GATEWAY (192, 168, 1, 1);
static const IPAddress STATIC_SUBNET  (255, 255, 255, 0);
static const IPAddress STATIC_DNS1    (192, 168, 1, 1);
static const IPAddress STATIC_DNS2    (8, 8, 8, 8);
